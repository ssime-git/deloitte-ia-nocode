POSTGRES_PASSWORD=changeme_secure_password

# n8n
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32
TIMEZONE=Europe/Paris

# Generate from the n8n UI after first start if you want API-backed preload/imports.
N8N_API_KEY=

# OpenAI gateway reused from the source repo pattern
OPENAI_API_KEY=
OPENAI_GATEWAY_API_KEY=
OPENAI_GATEWAY_BASE_URL=https://ai-gateway.liora.tech/v1
OPENAI_GATEWAY_MODEL=gpt-4.1-nano

# Learner workflow J6 MCP endpoint (allow override when another local MCP already uses port 8001)
MCP_SSE_ENDPOINT=http://mcp-server:8000/sse
