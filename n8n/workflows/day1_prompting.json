        780,
        360
      ]
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"lecture_metier\": \"résumé métier court\",\n  \"risques_audit\": [\"risque 1\", \"risque 2\"],\n  \"questions_de_controle\": [{\"question\": \"question à poser\"}],\n  \"anonymisation_requise\": false,\n  \"niveau_sensibilite\": \"Moyen\"\n}"
      },
      "id": "day1-output-parser",
      "name": "Format JSON attendu",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
