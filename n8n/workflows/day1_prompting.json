    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "day1-normalized-sensitivity",
              "name": "niveau_sensibilite",
              "value": "={{ (() => { const raw = (($json.niveau_sensibilite || '').toString().trim().toLowerCase()); if (raw === 'faible') return 'Faible'; if (raw === 'moyen') return 'Moyen'; if (raw === 'eleve' || raw === 'élevé') return 'Eleve'; return 'Moyen'; })() }}",
              "type": "string"
            }
          ]
        },
        "options": {
          "includeOtherFields": true
        }
      },
      "id": "day1-normalize-sensitivity",
      "name": "Normaliser sensibilité",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1060,
        360
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true
          },
          "conditions": [
            {
              "id": "day1-if-valid",
              "leftValue": "={{ ['Faible','Moyen','Eleve'].includes($json.niveau_sensibilite) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "day1-if",
      "name": "Sensibilite valide ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
