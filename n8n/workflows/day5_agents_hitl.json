              "type": "string"
            },
            {
              "id": "d5-ko-comment",
              "name": "motif_rejet",
              "value": "={{ $json[\"Commentaire\"] ?? 'Motif non renseigné' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "d5-rejected",
      "name": "Synthèse rejetée",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
